{
  "name": "protoagent",
  "version": "0.1.21",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "protoagent": "./dist/cli.js",
    "protoagent-api": "./dist/api/cli.js"
  },
  "scripts": {
    "clean": "bun -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "bun src/cli.ts",
    "dev:api": "bun src/api/cli.ts",
    "dev:web": "bun run --cwd web dev",
    "dev:all": "concurrently \"bun run dev:api\" \"bun run dev:web\" --kill-others",
    "build:web": "bun run --cwd web build",
    "test": "bun test",
    "build:cli": "bun build src/cli.ts --outdir dist --target bun --format esm && chmod +x dist/cli.js",
    "build:api": "bun build src/api/cli.ts --outdir dist/api --target bun --format esm && chmod +x dist/api/cli.js",
    "build": "bun run build:cli && bun run build:api",
    "build:watch": "bun build src/cli.ts --outdir dist --target bun --format esm --watch",
    "prepack": "bun run build",
    "docs:dev": "concurrently \"npm run docs:dev:worker\" \"npm run docs:dev:docs\" --kill-others",
    "docs:dev:worker": "cd docs/worker && npm exec wrangler -- dev --port 8787 --ip 0.0.0.0",
    "docs:dev:docs": "vitepress dev docs --port 5173 --host",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "author": "Thomas Gauvin",
  "license": "MIT",
  "homepage": "https://protoagent.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasgauvin/protoagent.git"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-agent",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "terminal",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentui/core": "^0.1.97",
    "commander": "^14.0.1",
    "diff": "^8.0.4",
    "hono": "^4.7.10",
    "he": "^1.2.0",
    "html-to-text": "^9.0.5",
    "jsonc-parser": "^3.3.1",
    "leven": "^4.1.0",
    "openai": "^5.23.1",
    "turndown": "^7.2.2",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/he": "^1.2.3",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^24.5.2",
    "@types/turndown": "^5.0.6",
    "concurrently": "^9.1.2",
    "typescript": "^5.9.2"
  }
}
